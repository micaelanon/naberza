# Naberza OS — Local Development Environment Template
# Copy to .env.local and fill in your values

# ==============================================================================
# DATABASE (Docker Compose)
# ==============================================================================
# Note: When using docker-compose up, PostgreSQL runs in a container.
# These values are used both by docker-compose.yml and the app.

DATABASE_URL=postgresql://naberza:postgres@localhost:5432/naberza_dev

# Docker Compose PostgreSQL credentials
POSTGRES_USER=naberza
POSTGRES_PASSWORD=postgres
POSTGRES_DB=naberza_dev

# ==============================================================================
# NEXTAUTH.JS (Authentication)
# ==============================================================================
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=

# URL where your app is accessible (for OAuth callbacks)
NEXTAUTH_URL=http://localhost:3000

# Single-user credentials (temporary; Phase 1 moves to DB-based auth)
AUTH_ADMIN_EMAIL=user@example.com
AUTH_ADMIN_PASSWORD=

# ==============================================================================
# APPLICATION
# ==============================================================================
NODE_ENV=development
LOG_LEVEL=info

# API base URL (used by client-side code)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# ==============================================================================
# EXTERNAL INTEGRATIONS (Phase 1+)
# ==============================================================================
# Uncomment and fill in as you implement each integration

# Paperless-ngx (Phase 2)
# PAPERLESS_API_URL=https://paperless.example.com/api
# PAPERLESS_API_TOKEN=

# Home Assistant (Phase 3)
# HOME_ASSISTANT_URL=http://homeassistant.local:8123
# HOME_ASSISTANT_TOKEN=

# IMAP Email (Phase 4)
# MAILBOX_IMAP_HOST=imap.gmail.com
# MAILBOX_IMAP_USER=your-email@gmail.com
# MAILBOX_IMAP_PASSWORD=

# Telegram Bot (Phase 7)
# TELEGRAM_BOT_TOKEN=

# ==============================================================================
# OPTIONAL: Supabase
# ==============================================================================
# Currently using PostgreSQL via Prisma; Supabase configs are placeholders
# for future multi-tenant scenarios
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
