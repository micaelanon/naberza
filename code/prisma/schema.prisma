// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USERS module
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Application relations
  preferences UserPreference[]
  telegramPreference TelegramPreference?
  intelligentSummaries IntelligentSummary[]
  quickActions QuickAction[]
  emailCleanupRules EmailCleanupRule[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  key       String
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("user_preferences")
}

// ─────────────────────────────────────────────
// INTEGRATIONS module
// ─────────────────────────────────────────────

model SourceConnection {
  id               String           @id @default(cuid())
  name             String
  type             ConnectionType
  status           ConnectionStatus @default(INACTIVE)
  config           Json             // encrypted at application level
  permissionRead   Boolean          @default(true) @map("permission_read")
  permissionWrite  Boolean          @default(false) @map("permission_write")
  lastHealthCheck  DateTime?        @map("last_health_check")
  lastError        String?          @map("last_error")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  inboxItems InboxItem[]
  homeEvents HomeEvent[]

  @@map("source_connections")
}

enum ConnectionType {
  PAPERLESS
  HOME_ASSISTANT
  EMAIL_IMAP
  EMAIL_WEBHOOK
  API
  CUSTOM
}

enum ConnectionStatus {
  ACTIVE
  INACTIVE
  ERROR
}

// ─────────────────────────────────────────────
// INBOX module
// ─────────────────────────────────────────────

model InboxItem {
  id                      String              @id @default(cuid())
  title                   String
  body                    String?             @db.Text
  sourceType              InboxSourceType     @map("source_type")
  sourceConnectionId      String?             @map("source_connection_id")
  sourceExternalId        String?             @map("source_external_id")
  sourceRawPayload        Json?               @map("source_raw_payload")
  classification          InboxClassification?
  classifiedBy            ClassifiedBy?       @map("classified_by")
  classificationConfidence Float?             @map("classification_confidence")
  status                  InboxStatus         @default(PENDING)
  routedToModule          String?             @map("routed_to_module")
  routedToEntityId        String?             @map("routed_to_entity_id")
  priority                Priority            @default(NONE)
  metadata                Json?
  processedAt             DateTime?           @map("processed_at")
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  sourceConnection SourceConnection? @relation(fields: [sourceConnectionId], references: [id])

  // Relations to entities this item was routed to
  task     Task?
  document Document?
  invoice  Invoice?
  idea     Idea?

  @@index([status])
  @@index([classification])
  @@index([sourceType])
  @@index([priority])
  @@index([createdAt(sort: Desc)])
  @@map("inbox_items")
}

enum InboxSourceType {
  EMAIL
  PAPERLESS
  HOME_ASSISTANT
  MANUAL
  API
}

enum InboxClassification {
  TASK
  DOCUMENT
  INVOICE
  EVENT
  ALERT
  IDEA
  FINANCIAL
  REVIEW
}

enum ClassifiedBy {
  RULE
  AI_SUGGESTION
  MANUAL
}

enum InboxStatus {
  PENDING
  CLASSIFIED
  ROUTED
  DISMISSED
  FAILED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
  NONE
}

// ─────────────────────────────────────────────
// TASKS module
// ─────────────────────────────────────────────

model Task {
  id             String     @id @default(cuid())
  title          String
  description    String?    @db.Text
  priority       Priority   @default(NONE)
  kind           TaskKind   @default(NORMAL)
  status         TaskStatus @default(PENDING)
  dueAt          DateTime?  @map("due_at")
  recurrenceRule String?    @map("recurrence_rule")
  tags           String[]
  inboxItemId    String?    @unique @map("inbox_item_id")
  completedAt    DateTime?  @map("completed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  inboxItem InboxItem? @relation(fields: [inboxItemId], references: [id])

  @@index([status])
  @@index([dueAt])
  @@index([kind])
  @@map("tasks")
}

enum TaskKind {
  NORMAL
  PERSISTENT
  RECURRING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────
// DOCUMENTS module
// ─────────────────────────────────────────────

model Document {
  id                 String           @id @default(cuid())
  title              String
  externalId         String           @map("external_id")
  externalUrl        String?          @map("external_url")
  sourceConnectionId String           @map("source_connection_id")
  documentType       DocumentType     @default(OTHER) @map("document_type")
  correspondent      String?
  tags               String[]
  contentPreview     String?          @map("content_preview") @db.Text
  archivedAt         DateTime?        @map("archived_at")
  inboxItemId        String?          @unique @map("inbox_item_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  inboxItem InboxItem? @relation(fields: [inboxItemId], references: [id])
  invoices  Invoice[]

  @@unique([sourceConnectionId, externalId])
  @@index([documentType])
  @@index([createdAt(sort: Desc)])
  @@map("documents")
}

enum DocumentType {
  INVOICE
  CONTRACT
  RECEIPT
  LETTER
  CERTIFICATE
  OTHER
}

// ─────────────────────────────────────────────
// INVOICES module
// ─────────────────────────────────────────────

model Invoice {
  id          String        @id @default(cuid())
  issuer      String
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("EUR")
  issueDate   DateTime      @map("issue_date") @db.Date
  dueDate     DateTime?     @map("due_date") @db.Date
  status      InvoiceStatus @default(PENDING)
  category    String?
  isRecurring Boolean       @default(false) @map("is_recurring")
  documentId  String?       @map("document_id")
  inboxItemId String?       @unique @map("inbox_item_id")
  paidAt      DateTime?     @map("paid_at")
  notes       String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  document         Document?        @relation(fields: [documentId], references: [id])
  inboxItem        InboxItem?       @relation(fields: [inboxItemId], references: [id])
  financialEntries FinancialEntry[]

  @@index([status])
  @@index([dueDate])
  @@index([issuer])
  @@index([isRecurring])
  @@index([createdAt(sort: Desc)])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  DISPUTED
  CANCELLED
}

// ─────────────────────────────────────────────
// FINANCE module
// ─────────────────────────────────────────────

model FinancialEntry {
  id            String            @id @default(cuid())
  type          FinancialEntryType
  amount        Decimal           @db.Decimal(12, 2)
  currency      String            @default("EUR")
  category      String?
  description   String?
  date          DateTime          @db.Date
  invoiceId     String?           @map("invoice_id")
  isAnomaly     Boolean           @default(false) @map("is_anomaly")
  anomalyReason String?           @map("anomaly_reason")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([type])
  @@index([date])
  @@index([isAnomaly])
  @@index([createdAt(sort: Desc)])
  @@map("financial_entries")
}

enum FinancialEntryType {
  INCOME
  EXPENSE
  BALANCE_SNAPSHOT
  RECURRING_CHARGE
}

// ─────────────────────────────────────────────
// HOME module
// ─────────────────────────────────────────────

model HomeEvent {
  id                 String          @id @default(cuid())
  eventType          String          @map("event_type")
  entityId           String          @map("entity_id")
  state              String?
  previousState      String?         @map("previous_state")
  attributes         Json?
  sourceConnectionId String          @map("source_connection_id")
  severity           HomeSeverity    @default(INFO)
  acknowledgedAt     DateTime?       @map("acknowledged_at")
  createdAt          DateTime        @default(now()) @map("created_at")

  sourceConnection SourceConnection @relation(fields: [sourceConnectionId], references: [id])

  @@index([eventType])
  @@index([entityId])
  @@index([severity])
  @@index([createdAt(sort: Desc)])
  @@map("home_events")
}

enum HomeSeverity {
  INFO
  WARNING
  CRITICAL
}

// ─────────────────────────────────────────────
// IDEAS module
// ─────────────────────────────────────────────

model Idea {
  id                String     @id @default(cuid())
  title             String
  body              String?    @db.Text
  tags              String[]
  status            IdeaStatus @default(CAPTURED)
  promotedToModule  String?    @map("promoted_to_module")
  promotedToEntityId String?   @map("promoted_to_entity_id")
  inboxItemId       String?    @unique @map("inbox_item_id")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  inboxItem InboxItem? @relation(fields: [inboxItemId], references: [id])

  @@index([status])
  @@map("ideas")
}

enum IdeaStatus {
  CAPTURED
  REVIEWED
  PROMOTED
  ARCHIVED
}

// ─────────────────────────────────────────────
// AUTOMATIONS module
// ─────────────────────────────────────────────

model AutomationRule {
  id               String    @id @default(cuid())
  name             String
  description      String?
  triggerEvent     String    @map("trigger_event")
  conditions       Json
  actions          Json
  requiresApproval Boolean   @default(false) @map("requires_approval")
  enabled          Boolean   @default(true)
  priority         Int       @default(0)
  lastTriggeredAt  DateTime? @map("last_triggered_at")
  executionCount   Int       @default(0) @map("execution_count")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  approvalRequests ApprovalRequest[]

  @@index([enabled])
  @@index([triggerEvent])
  @@index([enabled, triggerEvent])
  @@map("automation_rules")
}

model ApprovalRequest {
  id                   String          @id @default(cuid())
  automationRuleId     String          @map("automation_rule_id")
  triggerEventPayload  Json            @map("trigger_event_payload")
  proposedActions      Json            @map("proposed_actions")
  status               ApprovalStatus  @default(PENDING)
  decidedAt            DateTime?       @map("decided_at")
  expiresAt            DateTime        @map("expires_at")
  reason               String?
  createdAt            DateTime        @default(now()) @map("created_at")

  automationRule AutomationRule @relation(fields: [automationRuleId], references: [id])

  @@index([status])
  @@index([expiresAt])
  @@map("approval_requests")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
}

// ─────────────────────────────────────────────
// AUDIT module
// ─────────────────────────────────────────────

model AuditEvent {
  id          String      @id @default(cuid())
  module      String
  action      String
  entityType  String?     @map("entity_type")
  entityId    String?     @map("entity_id")
  actor       AuditActor
  actorDetail String?     @map("actor_detail")
  input       Json?
  output      Json?
  status      AuditStatus
  errorMessage String?    @map("error_message")
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")

  // Append-only: no updatedAt, no soft delete
  @@index([module])
  @@index([module, action])
  @@index([entityType, entityId])
  @@index([actor])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("audit_events")
}

enum AuditActor {
  USER
  SYSTEM
  AUTOMATION
  INTEGRATION
}

enum AuditStatus {
  SUCCESS
  FAILURE
  PENDING
}

// ─────────────────────────────────────────────
// EMAIL ADVANCED FEATURES module
// ─────────────────────────────────────────────

// Phase 1: Telegram Alerts & Preferences
model TelegramPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  telegramUserId      Int?     @map("telegram_user_id")
  telegramUsername    String?  @map("telegram_username")
  telegramEnabled     Boolean  @default(false) @map("telegram_enabled")
  verificationCode    String?  @map("verification_code")
  verificationExpires DateTime? @map("verification_expires")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts TelegramAlert[]
  messages TelegramMessage[]

  @@map("telegram_preferences")
}

model TelegramAlert {
  id                    String   @id @default(cuid())
  telegramPreferenceId  String   @map("telegram_preference_id")
  name                  String
  description           String?  @db.Text
  triggerType           AlertTriggerType @map("trigger_type")
  // triggerType-specific config: e.g., {"senderEmails": ["important@example.com"], "keywords": ["invoice"]}
  config                Json
  enabled               Boolean  @default(true)
  priority              Priority @default(MEDIUM)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  telegramPreference TelegramPreference @relation(fields: [telegramPreferenceId], references: [id], onDelete: Cascade)

  @@index([telegramPreferenceId])
  @@index([enabled])
  @@map("telegram_alerts")
}

enum AlertTriggerType {
  PRIORITY_SENDER    // Alert if email from VIP contacts
  KEYWORD            // Alert if keywords in subject/body
  UNPAID_INVOICE     // Alert for unpaid invoices
  URGENT_TASK        // Alert for overdue tasks
  FINANCE_SUMMARY    // Alert for finance milestones
  DAILY_DIGEST       // Alert with daily summary
  WEEKLY_DIGEST      // Alert with weekly summary
}

model TelegramMessage {
  id                   String   @id @default(cuid())
  telegramPreferenceId String   @map("telegram_preference_id")
  messageId            String   @unique @map("message_id") // Telegram message ID
  text                 String   @db.Text
  parseMode            String   @default("HTML") @map("parse_mode")
  sentAt               DateTime @default(now()) @map("sent_at")
  status               MessageStatus @default(PENDING)
  error                String?  @db.Text
  retryCount           Int      @default(0) @map("retry_count")

  telegramPreference TelegramPreference @relation(fields: [telegramPreferenceId], references: [id], onDelete: Cascade)

  @@index([telegramPreferenceId])
  @@index([status])
  @@index([sentAt])
  @@map("telegram_messages")
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

// Phase 2: Email Cleanup Rules
model EmailCleanupRule {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  name            String
  description     String?  @db.Text
  matchType       CleanupMatchType @map("match_type")
  // matchType-specific config: e.g., {"senders": [], "keywords": [], "ageInDays": 90}
  config          Json
  action          CleanupAction
  enabled         Boolean  @default(true)
  priority        Int      @default(0)
  dryRunEnabled   Boolean  @default(true) @map("dry_run_enabled")
  lastExecutedAt  DateTime? @map("last_executed_at")
  matchedCount    Int      @default(0) @map("matched_count")
  executedCount   Int      @default(0) @map("executed_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  logs EmailCleanupLog[]

  @@index([userId])
  @@index([enabled])
  @@map("email_cleanup_rules")
}

enum CleanupMatchType {
  SENDER
  KEYWORD
  NEWSLETTER
  OLD_EMAILS
  SIZE_THRESHOLD
  READ_STATUS
  CUSTOM
}

enum CleanupAction {
  DELETE
  ARCHIVE
  LABEL
  MOVE_TO_FOLDER
}

model EmailCleanupLog {
  id           String   @id @default(cuid())
  ruleId       String   @map("rule_id")
  inboxItemId  String   @map("inbox_item_id")
  action       CleanupAction
  wasPreview   Boolean  @default(true) @map("was_preview")
  executedAt   DateTime @default(now()) @map("executed_at")

  rule EmailCleanupRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([executedAt])
  @@map("email_cleanup_logs")
}

// Phase 3: Invoice Extraction
model InvoiceExtractionLog {
  id                   String   @id @default(cuid())
  inboxItemId          String   @map("inbox_item_id")
  extractionMethod     ExtractionMethod @map("extraction_method")
  extractionConfidence Float?   @map("extraction_confidence")
  rawPdfPath           String?  @map("raw_pdf_path")
  ocrFullText          String?  @map("ocr_full_text") @db.Text
  extractedInvoiceId   String?  @map("extracted_invoice_id")
  status               ExtractionStatus
  error                String?  @db.Text
  createdAt            DateTime @default(now()) @map("created_at")
  completedAt          DateTime? @map("completed_at")

  @@index([inboxItemId])
  @@index([status])
  @@index([createdAt])
  @@map("invoice_extraction_logs")
}

enum ExtractionMethod {
  OCR
  STRUCTURED_PDF
  AI_VISION
  MANUAL
}

enum ExtractionStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  MANUAL_REVIEW
}

// Phase 4: Intelligent Summaries
model IntelligentSummary {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  summaryType         SummaryType @map("summary_type")
  period              String   // "daily" or "weekly"
  startDate           DateTime @map("start_date")
  endDate             DateTime @map("end_date")
  metrics             Json     // {emailCount, invoicesDue, tasksCompleted, ...}
  content             String   @db.Text
  deliveryChannels    String[] @map("delivery_channels") // ["email", "telegram"]
  deliveredAt         DateTime? @map("delivered_at")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([summaryType])
  @@index([createdAt])
  @@map("intelligent_summaries")
}

enum SummaryType {
  DAILY
  WEEKLY
  MONTHLY
}

// Phase 5: Quick Actions
model QuickAction {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  name            String
  description     String?  @db.Text
  targetType      QuickActionTargetType @map("target_type")
  // targetType-specific actions: e.g., {"action": "archive", "label": "newsletters"}
  config          Json
  enabled         Boolean  @default(true)
  priority        Int      @default(0)
  executionCount  Int      @default(0) @map("execution_count")
  lastUsedAt      DateTime? @map("last_used_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  logs QuickActionLog[]

  @@index([userId])
  @@index([targetType])
  @@map("quick_actions")
}

enum QuickActionTargetType {
  EMAIL
  INVOICE
  TASK
  DOCUMENT
  IDEA
  BATCH
}

model QuickActionLog {
  id           String   @id @default(cuid())
  actionId     String   @map("action_id")
  entityId     String   @map("entity_id")
  entityType   String   @map("entity_type")
  result       ActionResult
  error        String?  @db.Text
  executedAt   DateTime @default(now()) @map("executed_at")

  action QuickAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([actionId])
  @@index([executedAt])
  @@map("quick_action_logs")
}

enum ActionResult {
  SUCCESS
  FAILURE
  PARTIAL
}
