hboard/email-triage-view/use-email-triage.ts:151:26\n  149 |\n  150 |   // eslint-disable-next-line react-hooks/set-state-in-effect\n> 151 |   useEffect(() => { void loadHistory(); }, [loadHistory]);\n      |                          ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  152 |\n  153 |   const progressPct = useMemo(() => {\n  154 |     if (!session) return 0;",["2035"],{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2038"},{"kind":"2036","justification":"2038"},{"kind":"2036","justification":"2039"},{"kind":"2036","justification":"2040"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},{"kind":"2036","justification":"2037"},"directive","","tutorial examples","Material Symbols is not available via next/font","test suite with multiple describe blocks"]