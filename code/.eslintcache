ix/code/src/app/email/dashboard/components/telegram-alerts-panel.tsx:25:7\n  23 |   useEffect(() => {\n  24 |     if (preference?.id && preference?.telegramEnabled) {\n> 25 |       fetchAlerts();\n     |       ^^^^^^^^^^^ `fetchAlerts` accessed before it is declared\n  26 |     }\n  27 |   }, [preference?.id]);\n  28 |\n\n/private/tmp/naberza-fix/code/src/app/email/dashboard/components/telegram-alerts-panel.tsx:29:3\n  27 |   }, [preference?.id]);\n  28 |\n> 29 |   const fetchAlerts = async () => {\n     |   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 30 |     if (!preference?.id) return;\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 31 |     try {\n     …\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 39 |     }\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 40 |   };\n     | ^^^^^ `fetchAlerts` is declared here\n  41 |\n  42 |   const handleAlertCreated = async () => {\n  43 |     setShowForm(false);","react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'fetchAlerts' and 'preference?.telegramEnabled'. Either include them or remove the dependency array.","ArrayExpression",["1994"],["1995","1996"],"Error: Cannot access variable before it is declared\n\n`fetchPreference` is accessed before it is declared, which prevents the earlier access from updating when this value changes over time.\n\n/private/tmp/naberza-fix/code/src/app/email/dashboard/email-view/email-view.tsx:17:5\n  15 |   useEffect(() => {\n  16 |     // Check if user has Telegram preference\n> 17 |     fetchPreference();\n     |     ^^^^^^^^^^^^^^^ `fetchPreference` accessed before it is declared\n  18 |   }, []);\n  19 |\n  20 |   const fetchPreference = async () => {\n\n/private/tmp/naberza-fix/code/src/app/email/dashboard/email-view/email-view.tsx:20:3\n  18 |   }, []);\n  19 |\n> 20 |   const fetchPreference = async () => {\n     |   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 21 |     try {\n     | ^^^^^^^^^\n> 22 |       const res = await fetch('/api/notifications/telegram/preferences');\n     …\n     | ^^^^^^^^^\n> 31 |     }\n     | ^^^^^^^^^\n> 32 |   };\n     | ^^^^^ `fetchPreference` is declared here\n  33 |\n  34 |   return (\n  35 |     <div className=\"email-dashboard\">","react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/private/tmp/naberza-fix/code/src/app/finance/dashboard/finance-view/finance-view.tsx:228:5\n  226 |   useEffect(() => {\n  227 |     let cancelled = false;\n> 228 |     fetchEntries() // eslint-disable-line react-hooks/set-state-in-effect\n      |     ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  229 |       .catch(() => { /* handled inside fetchEntries */ })\n  230 |       .finally(() => { if (cancelled) return; });\n  231 |     return () => { cancelled = true; };",["1997"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/private/tmp/naberza-fix/code/src/app/ideas/dashboard/ideas-view/ideas-view.tsx:200:5\n  198 |   useEffect(() => {\n  199 |     let cancelled = false;\n> 200 |     fetchIdeas() // eslint-disable-line react-hooks/set-state-in-effect\n      |     ^^^^^^^^^^ Avoid calling setState() directly within an effect\n  201 |       .catch(() => { /* handled inside fetchIdeas */ })\n  202 |       .finally(() => { if (cancelled) return; });\n  203 |     return () => { cancelled = true; };",["1998"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/private/tmp/naberza-fix/code/src/app/inbox/dashboard/inbox-view/inbox-view.tsx:278:5\n  276 |   useEffect(() => {\n  277 |     let cancelled = false;\n> 278 |     fetchItems(activeTab) // eslint-disable-line react-hooks/set-state-in-effect\n      |     ^^^^^^^^^^ Avoid calling setState() directly within an effect\n  279 |       .catch(() => { /* handled inside fetchItems */ })\n  280 |       .finally(() => { if (cancelled) return; });\n  281 |     return () => { cancelled = true; };",["1999"],"sonarjs/no-hardcoded-passwords","Review this potentially hard-coded password.","TemplateLiteral","reviewPassword",["2000"],["2001"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/private/tmp/naberza-fix/code/src/app/invoices/dashboard/invoices-view/invoices-view.tsx:237:5\n  235 |   useEffect(() => {\n  236 |     let cancelled = false;\n> 237 |     fetchInvoices() // eslint-disable-line react-hooks/set-state-in-effect\n      |     ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  238 |       .catch(() => { /* handled inside fetchInvoices */ })\n  239 |       .finally(() => { if (cancelled) return; });\n  240 |     return () => { cancelled = true; };",["2002"],"@next/next/no-page-custom-font","Custom fonts not added in `pages/_document.js` will only load for a single page. This is discouraged. See: https://nextjs.org/docs/messages/no-page-custom-font","JSXOpeningElement",["2003"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/private/tmp/naberza-fix/code/src/app/tasks/dashboard/tasks-view/tasks-view.tsx:407:5\n  405 |   useEffect(() => {\n  406 |     let cancelled = false;\n> 407 |     fetchTasks(activeTab) // eslint-disable-line react-hooks/set-state-in-effect\n      |     ^^^^^^^^^^ Avoid calling setState() directly within an effect\n  408 |       .catch(() => { /* handled inside fetchTasks */ })\n  409 |       .finally(() => { if (cancelled) return; });\n  410 |     return () => { cancelled = true; };",["2004"],"Arrow function has too many lines (178). Maximum allowed is 140.","ArrowFunctionExpression",["2005"],"sonarjs/no-clear-text-protocols","Using http protocol is insecure. Use https instead.","Literal","insecureProtocol",["2006"],["2007"],["2008"],["2009"],"'retryErr' is defined but never used.",["2010"],["2011"],["2012"],["2013"],["2014"],["2015"],["2016"],["2017"],["2018","2019"],["2020","2021"],["2022","2023"],["2024","2025"],["2026"],["2027"],["2028"],["2029"],"sonarjs/no-nested-assignment","Extract the assignment of \"acc[p.category]\" from this expression.","extractAssignment","Async method 'executeCleanup' has a complexity of 12. Maximum allowed is 10.","FunctionExpression","Refactor this function to reduce its Cognitive Complexity from 16 to the 12 allowed.",["2030","2031"],["2032","2033"],"Method 'matchKeywordEmail' has a complexity of 11. Maximum allowed is 10.","Method 'matchNewsletterEmail' has a complexity of 12. Maximum allowed is 10.","regexp/no-unused-capturing-group","Capturing group number 1 is defined but never used.","unusedCapturingGroup",["2034"],["2035"],"Method 'extractSender' has a complexity of 11. Maximum allowed is 10.","sonarjs/slow-regex","Make sure the regex used here, which is vulnerable to super-linear runtime due to backtracking, cannot lead to denial of service.",["2036","2037"],"sonarjs/todo-tag","Complete the task associated to this \"TODO\" comment.","completeT