{
  "name": "naberza-os",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --cache",
    "type-check": "tsc --noEmit",
    "check:duplication": "jscpd --config .jscpd.json src",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run type-check && npm run test:run && npm run check:duplication",
    "db:seed": "tsx prisma/seed.ts",
    "db:clear-seed": "npx prisma db execute --stdin < prisma/clear-seed.sql",
    "db:migrate": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@prisma/client": "^6.3.1",
    "@supabase/supabase-js": "^2.103.0",
    "imapflow": "^1.3.1",
    "next": "16.2.3",
    "next-auth": "4.24.14",
    "nodemailer": "^8.0.5",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/next-auth": "^3.15.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "jscpd": "^4.0.9",
    "jsdom": "^23.0.1",
    "prisma": "^6.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^1.1.0"
  }
}
