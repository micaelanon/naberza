# ==============================================================================
# NEXTAUTH.JS (Authentication)
# ==============================================================================
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Single-user admin credentials (used by CredentialsProvider until DB auth in Phase 1)
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_PASSWORD=

# ==============================================================================
# DATABASE (PostgreSQL via Prisma)
# ==============================================================================
DATABASE_URL=postgresql://naberza:postgres@localhost:5432/naberza_dev

# Docker Compose overrides (used in docker-compose.yml)
POSTGRES_USER=naberza
POSTGRES_PASSWORD=postgres
POSTGRES_DB=naberza_dev

# ==============================================================================
# APPLICATION
# ==============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NODE_ENV=development
LOG_LEVEL=info

# ==============================================================================
# EXTERNAL INTEGRATIONS (Phase 1+)
# ==============================================================================

# Paperless-ngx (Phase 2: Document management)
# PAPERLESS_API_URL=https://paperless.example.com/api
# PAPERLESS_API_TOKEN=

# Home Assistant (Phase 3: Home automation)
# HOME_ASSISTANT_URL=http://homeassistant.local:8123
# HOME_ASSISTANT_TOKEN=

# IMAP Mail (Phase 4: Email ingestion)
# MAILBOX_IMAP_HOST=imap.gmail.com
# MAILBOX_IMAP_USER=
# MAILBOX_IMAP_PASSWORD=

# Telegram Notifications (Phase 5: Automation notifications)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_DEFAULT_CHAT_ID=

# SMTP Email Notifications (Phase 5: Automation notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=naberza@example.com
# SMTP_DEFAULT_TO=admin@example.com

# Anthropic (Phase 8: AI email triage)
ANTHROPIC_API_KEY=sk-ant-...

# ==============================================================================
# OPTIONAL: Supabase (if used for integration beyond Prisma)
# ==============================================================================
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
